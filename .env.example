# ═══════════════════════════════════════════════════════════════════
#  feeti2 — Frontend — Variables d'environnement (Vite)
#  Copier ce fichier en .env et remplir les valeurs
#  Toutes les variables DOIVENT commencer par VITE_
# ═══════════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000

# ── Cross-app — feetiPlay ────────────────────────────────────────────
VITE_FEETIPLAY_URL=http://localhost:5173

# ── Paiements (Simulation — clés publiques uniquement) ───────────────
# Stripe (clé publique — pk_test_ en dev, pk_live_ en prod)
VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX

# Paystack (clé publique)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
