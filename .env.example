# ═══════════════════════════════════════════════════════════════════
#  feeti2 — Frontend — Variables d'environnement (Vite)
#  Copier ce fichier en .env et remplir les valeurs
#  Toutes les variables DOIVENT commencer par VITE_
# ═══════════════════════════════════════════════════════════════════

# ── API Firebase (Cloud Functions) ────────────────────────────────────
# Développement (emulateur Firebase)
VITE_BACKEND_URL=http://localhost:5001/feeti2-dev/europe-west1/api
# Production : https://europe-west1-feeti2-prod.cloudfunctions.net/api
# (ou via Firebase Hosting : /api — pas besoin d'URL absolue en prod)

# ── Cross-app — feetiPlay ────────────────────────────────────────────
VITE_FEETIPLAY_URL=http://localhost:5173

# ── Firebase (projet feeti2) ─────────────────────────────────────────
# Obtenir sur console.firebase.google.com > feeti2-dev > Paramètres du projet
VITE_FIREBASE_API_KEY=CHANGE_ME
VITE_FIREBASE_AUTH_DOMAIN=feeti2-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=feeti2-dev
VITE_FIREBASE_STORAGE_BUCKET=feeti2-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
VITE_FIREBASE_APP_ID=CHANGE_ME
VITE_FIREBASE_MEASUREMENT_ID=CHANGE_ME

# ── Paiements (clés publiques uniquement) ────────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
VITE_PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
